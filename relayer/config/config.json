{
  "relayers": [
    {
      "id": "stellar-testnet",
      "name": "Lumenitos Stellar Testnet Relayer",
      "network": "testnet",
      "paused": false,
      "notification_id": "notification-webhook",
      "signer_id": "local-signer",
      "network_type": "stellar",
      "policies": {
        "fee_payment_strategy": "relayer",
        "min_balance": 50000000,
        "max_fee": 10000000,
        "timeout_seconds": 30
      }
    }
  ],
  "signers": [
    {
      "id": "local-signer",
      "type": "local",
      "config": {
        "path": "config/keys/local-signer.json",
        "passphrase": {
          "type": "env",
          "value": "KEYSTORE_PASSPHRASE"
        }
      }
    }
  ],
  "notifications": [
    {
      "id": "notification-webhook",
      "type": "webhook",
      "url": "http://localhost:9999/webhook",
      "signing_key": {
        "type": "env",
        "value": "WEBHOOK_SIGNING_KEY"
      }
    }
  ],
  "networks": [
    {
      "type": "stellar",
      "network": "testnet",
      "rpc_urls": ["https://soroban-testnet.stellar.org"],
      "explorer_urls": ["https://stellar.expert/explorer/testnet"],
      "average_blocktime_ms": 5000,
      "is_testnet": true,
      "passphrase": "Test SDF Network ; September 2015",
      "horizon_url": "https://horizon-testnet.stellar.org"
    }
  ],
  "plugins": []
}
